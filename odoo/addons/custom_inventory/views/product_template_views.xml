<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend product.template form view to show custom fields -->
    <record id="product_template_form_view_warehouse" model="ir.ui.view">
        <field name="name">product.template.form.warehouse</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="x_part_number" string="Part Number" required="1"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_brand" string="Brand"/>
            </xpath>
        </field>
    </record>

    <!-- Extend product.template tree/list view -->
    <record id="product_template_tree_view_warehouse" model="ir.ui.view">
        <field name="name">product.template.tree.warehouse</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="x_part_number" string="Part Number" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_brand" string="Brand" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
